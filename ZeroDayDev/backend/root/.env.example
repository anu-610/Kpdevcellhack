# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string

# ── Chat config ─────────────────────────────────────
CHAT_HISTORY_LIMIT=100        
CHAT_RATE_LIMIT_MAX=20       # max messages per user per minute